{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/node_modules/@evie-agent/cli/src/evie-agent.ts\" handoff precompact"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$CLAUDE_PROJECT_DIR/node_modules/@evie-agent/cli/src/evie-agent.ts\" handoff precompact"
          }
        ]
      }
    ]
  }
}
